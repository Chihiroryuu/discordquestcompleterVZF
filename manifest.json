{
  "manifest_version": 3,
  "name": "Bypass Quest Discord BY VZF PRO",
  "version": "1.4.8",
  "description": "Selesaikan Quest Discord tanpa main game. Script by VZF. YT: VeilZeroFun",
  "homepage_url": "https://linktr.ee/VeilZeroFun",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "activeTab",
    "storage",
    "notifications",
    "cookies"
  ],
  "host_permissions": [
    "https://discord.com/*",
    "https://script.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*"],
      "js": ["user-agent-check.js", "get-uid.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["https://discord.com/quest-home*"],
      "js": ["quest-home.js"],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["quest-code.js"],
      "matches": ["https://discord.com/*"]
    }
  ]
}